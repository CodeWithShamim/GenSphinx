# GenLayer Project Configuration

# The address of your deployed Intelligent Contract
# Get this from the output of 'npm run deploy'
NEXT_PUBLIC_CONTRACT_ADDRESS=

# GenLayer Network Settings (Studionet)
NEXT_PUBLIC_GENLAYER_RPC_URL=https://studio.genlayer.com/api
NEXT_PUBLIC_GENLAYER_CHAIN_ID=61999
NEXT_PUBLIC_GENLAYER_CHAIN_NAME=GenLayer Studio
NEXT_PUBLIC_GENLAYER_SYMBOL=GEN

# Reown AppKit Project ID (Get from https://cloud.reown.com)
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Optional: Custom Studio URL if running locally
# NEXT_PUBLIC_GENLAYER_RPC_URL=http://localhost:4000/api
